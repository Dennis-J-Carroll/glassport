 {"type": "number", "minimum": 1, "description": "Maximum characters to extract per page (must be a positive number, default: 3000)"}}, "required": ["urls"], "additionalProperties": false, "$schema": "http://json-schema.org/draft-07/schema#"}, "annotations": {"readOnlyHint": true, "destructiveHint": false, "openWorldHint": false, "idempotentHint": true}, "execution": {"taskSupport": "forbidden"}}]}, "jsonrpc": "2.0", "id": 2}, "raw": null}
